# CNPJ Data Pipeline Configuration

# Database (PostgreSQL unificado — docker-compose da raiz do m-hunt)
DATABASE_URL=postgres://hunt:hunt@localhost:5432/hunt

# Processing
BATCH_SIZE=500000
TEMP_DIR=./temp

# Downloads (parallel)
DOWNLOAD_WORKERS=4

# Network
RETRY_ATTEMPTS=3
RETRY_DELAY=5
CONNECT_TIMEOUT=30
READ_TIMEOUT=300

# Cleanup
KEEP_DOWNLOADED_FILES=false
